  "services": {
    "add_dhcp_reservation": {
      "name": "Add DHCP reservation",
      "description": "Reserve an IP for a MAC address.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "mac": { "name": "MAC", "description": "Device MAC address." },
        "ip": { "name": "IP", "description": "IP to reserve." },
        "name": { "name": "Name", "description": "Reservation label." }
      }
    },
    "remove_dhcp_reservation": {
      "name": "Remove DHCP reservation",
      "description": "Remove a reservation by MAC.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "mac": { "name": "MAC", "description": "Device MAC address." }
      }
    },
    "block_device": {
      "name": "Block device",
      "description": "Block a device from accessing the network by MAC.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "mac": { "name": "MAC", "description": "Device MAC address." }
      }
    },
    "unblock_device": {
      "name": "Unblock device",
      "description": "Unblock a previously blocked device by MAC.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "mac": { "name": "MAC", "description": "Device MAC address." }
      }
    },
    "luci_request": {
      "name": "Raw LuCI API request",
      "description": "Performs a read-only GET to any MiWiFi LuCI API path and returns the JSON.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "path": { "name": "API path", "description": "LuCI path, e.g. api/misystem/router_info." }
      }
    },
    "run_speed_test": {
      "name": "Run speed test",
      "description": "Trigger a WAN speed test on the router. Briefly saturates the connection.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." }
      }
    },
    "add_port_forward": {
      "name": "Add port forward",
      "description": "Add a single-port forwarding rule and apply it.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "ip": { "name": "Internal IP", "description": "LAN host to forward to." },
        "name": { "name": "Name", "description": "Rule label." },
        "proto": { "name": "Protocol", "description": "1=TCP, 2=UDP, 3=TCP+UDP." },
        "source_port": { "name": "External port", "description": "WAN-side port." },
        "dest_port": { "name": "Internal port", "description": "LAN-side port." }
      }
    },
    "delete_port_forward": {
      "name": "Delete port forward",
      "description": "Delete a port forwarding rule by its external port and apply.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "source_port": { "name": "External port", "description": "WAN-side port of the rule to delete." }
      }
    },
    "set_dmz": {
      "name": "Set DMZ",
      "description": "Forward all unmatched WAN traffic to a single LAN host.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "ip": { "name": "DMZ host IP", "description": "LAN host to expose." }
      }
    },
    "clear_dmz": {
      "name": "Clear DMZ",
      "description": "Disable DMZ forwarding.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." }
      }
    },
    "set_ddns": {
      "name": "Set DDNS",
      "description": "Enable or disable dynamic DNS on the router.",
      "fields": {
        "entry_id": { "name": "Router", "description": "Target router." },
        "enabled": { "name": "Enabled", "description": "Turn DDNS on or off." }
      }
    }
  }
